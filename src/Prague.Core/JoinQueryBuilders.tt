	[MethodImpl(MethodImplOptions.AggressiveInlining)]
	public static CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue,
		Resolvers<TResolverChain, <#= resolverCollFwdFilter #>>,
		<#= nextResultMany #>>
		JoinManyCollectionForward<#= methodTypeParamsColl #>(
			this in CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue, TResolverChain, <#= currentResultTypeParams #>> builder,
			IDataCache<TRightCache, TRightKey, TRightValue> rightCache,
