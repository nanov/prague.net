#>
public static class CacheQueryBuilderCombinedJoinNewLevel<#= level #>Extensions {

	// ── PK-to-PK identity: outer, no filter ──────────────────────────────────

	/// <summary>Outer join PK-to-PK with no filter (level <#= level #> → <#= level + 1 #>).</summary>
	[MethodImpl(MethodImplOptions.AggressiveInlining)]
	public static CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue,
		Resolvers<TResolverChain, <#= resolverNoFilter #>>,
		<#= nextResultTypeParams #>>
		JoinOne<#= methodTypeParams #>(
			this in CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue, TResolverChain, <#= currentResultTypeParams #>> builder,
			IDataCache<TRightCache, TKey, TRightValue> rightCache)
		where TExecutor : struct, ICandidatesExecutor<TKey, TValue>
		where TDiscriminator : struct, IBaseJoinable
		where TResolverChain : struct, IResolvers
		where TKey : notnull, IEquatable<TKey>
		where TValue : ICacheEquatable<TValue>, ICacheClonable<TValue>
		where TRightValue : ICacheEquatable<TRightValue>, ICacheClonable<TRightValue>
		where TRightCache : IDataCache<TRightCache, TKey, TRightValue> {
		var resolver = new <#= resolverNoFilter #>(
			(TRightCache)rightCache, default, default);
		return Unsafe.AsRef(in builder).AddResolver<
			Resolvers<TResolverChain, <#= resolverNoFilter #>>,
			<#= nextResultTypeParams #>>(
			new Resolvers<TResolverChain, <#= resolverNoFilter #>>(builder._resolverChain, resolver),
			false);
	}

	// ── PK-to-PK identity: outer, with filter ────────────────────────────────

	/// <summary>Outer join PK-to-PK with a lazily-applied filter on the right cache (level <#= level #> → <#= level + 1 #>).</summary>
	[MethodImpl(MethodImplOptions.AggressiveInlining)]
	public static CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue,
		Resolvers<TResolverChain, <#= resolverFilter #>>,
		<#= nextResultTypeParams #>>
		JoinOne<#= methodTypeParams #>(
			this in CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue, TResolverChain, <#= currentResultTypeParams #>> builder,
			IDataCache<TRightCache, TKey, TRightValue> rightCache,
			Func<<#= nonExecBuilder #>, <#= nonExecBuilder #>> filter)
		where TExecutor : struct, ICandidatesExecutor<TKey, TValue>
		where TDiscriminator : struct, IBaseJoinable
		where TResolverChain : struct, IResolvers
		where TKey : notnull, IEquatable<TKey>
		where TValue : ICacheEquatable<TValue>, ICacheClonable<TValue>
		where TRightValue : ICacheEquatable<TRightValue>, ICacheClonable<TRightValue>
		where TRightCache : IDataCache<TRightCache, TKey, TRightValue> {
		var resolver = new <#= resolverFilter #>(
			(TRightCache)rightCache,
			new <#= joinFilter #>(filter),
			default);
		return Unsafe.AsRef(in builder).AddResolver<
			Resolvers<TResolverChain, <#= resolverFilter #>>,
			<#= nextResultTypeParams #>>(
			new Resolvers<TResolverChain, <#= resolverFilter #>>(builder._resolverChain, resolver),
			false);
	}

	// ── PK-to-PK identity: outer, filter + arg ───────────────────────────────

	/// <summary>Outer join PK-to-PK with a TArg user-state and a static-lambda filter (level <#= level #> → <#= level + 1 #>).</summary>
	[MethodImpl(MethodImplOptions.AggressiveInlining)]
	public static CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue,
		Resolvers<TResolverChain, <#= resolverFilterArg #>>,
		<#= nextResultTypeParams #>>
		JoinOne<#= methodTypeParamsArg #>(
			this in CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue, TResolverChain, <#= currentResultTypeParams #>> builder,
			IDataCache<TRightCache, TKey, TRightValue> rightCache,
			Func<<#= nonExecBuilder #>, TArg, <#= nonExecBuilder #>> filter,
			TArg arg)
		where TExecutor : struct, ICandidatesExecutor<TKey, TValue>
		where TDiscriminator : struct, IBaseJoinable
		where TResolverChain : struct, IResolvers
		where TKey : notnull, IEquatable<TKey>
		where TValue : ICacheEquatable<TValue>, ICacheClonable<TValue>
		where TRightValue : ICacheEquatable<TRightValue>, ICacheClonable<TRightValue>
		where TRightCache : IDataCache<TRightCache, TKey, TRightValue> {
		var resolver = new <#= resolverFilterArg #>(
			(TRightCache)rightCache,
			new <#= joinFilterArg #>(filter, arg),
			default);
		return Unsafe.AsRef(in builder).AddResolver<
