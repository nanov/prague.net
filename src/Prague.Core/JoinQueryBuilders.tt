	// ── CRI3: inner, with filter + arg ───────────────────────────────────────
	[MethodImpl(MethodImplOptions.AggressiveInlining)]
	public static CacheQueryBuilderCombined<TDiscriminator, TExecutor, TKey, TValue,
		Resolvers<TResolverChain, <#= resolverCollRevFilterArg #>>,
