<#
	// ═══════════════════════════════════════════════════════════════════════════
	// Phase 4: JoinMany chained-level extensions
	// ═══════════════════════════════════════════════════════════════════════════
	// Two families × identity selector × 6 overloads each = 12 per level.
	//   1) JoinManyRightListIndexResolver identity (M1/M2/M3 outer + MI1/MI2/MI3 inner)
	//   2) JoinManyLeftSymResolver identity        (LS1/LS2/LS3 outer + LSI1/LSI2/LSI3 inner)
	// Output result type uses QueryResults<TRightValue> (not TRightValue?) since the
	// per-left payload is a many-to relation, not a 1:1 optional.

	// RightListIndex identity — paired-core's TLeft is TKey (vs LeftSym's LeftKeySetView<TKey>).
	var nonExecBuilderM = "CacheQueryBuilderCombined<NonExecutableQuery<TRightCache>, PairedCacheQueryBuilderCoreCombined<TKey, TRightKey, TRightValue>, TRightKey, TRightValue, Resolvers<BaseResolver<TRightKey, TRightValue>>, TRightValue>";
	var noFilterM = $"NoFilter<{nonExecBuilderM}>";
	var joinFilterM = $"JoinFilter<{nonExecBuilderM}>";
	var joinFilterArgM = $"JoinFilterWithArg<{nonExecBuilderM}, TArg>";
	var resolverNoFilterM = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TKey, TRightValue, {noFilterM}, IdentitySelector<TKey>>";
	var resolverFilterM = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TKey, TRightValue, {joinFilterM}, IdentitySelector<TKey>>";
	var resolverFilterArgM = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TKey, TRightValue, {joinFilterArgM}, IdentitySelector<TKey>>";
	var nextResultMany = $"JoinResult<TValue{extraTs}, QueryResults<TRightValue>>";
	var methodTypeParamsM = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TRightCache, TRightKey, TRightValue>";
	var methodTypeParamsMArg = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TRightCache, TRightKey, TArg, TRightValue>";

	// Nested (right-list resolver, inner-join continuation) — outer no-filter only (v1).
	// Seed discriminator is ExecutableQuery<TRightCache> (the wrapper) so codegen FK sugar composes inside the lambda.
	var seedBuilderNested = "CacheQueryBuilderCombined<ExecutableQuery<TRightCache>, CacheQueryBuilderCoreCombined<TRightKey, TRightValue>, TRightKey, TRightValue, Resolvers<BaseResolver<TRightKey, TRightValue>>, TRightValue>";
	var nestedBuilderNested = "CacheQueryBuilderCombined<TInnerDisc, TInnerExec, TRightKey, TRightValue, TInnerChain, TInnerResult>";
	var resolverNested = "JoinManyNestedResolver<TKey, TValue, TRightCache, TRightKey, TRightValue, TInnerDisc, TInnerExec, TInnerChain, TInnerResult>";
	var nextResultNested = $"JoinResult<TValue{extraTs}, QueryResults<TInnerResult>>";
	var methodTypeParamsNested = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TRightCache, TRightKey, TRightValue, TInnerDisc, TInnerExec, TInnerChain, TInnerResult>";

	// LeftSym identity — paired-core's TLeft is LeftKeySetView<TKey>; TLookupKey distinct.
	var nonExecBuilderLsM = "CacheQueryBuilderCombined<NonExecutableQuery<TRightCache>, PairedCacheQueryBuilderCoreCombined<LeftKeySetView<TKey>, TRightKey, TRightValue>, TRightKey, TRightValue, Resolvers<BaseResolver<TRightKey, TRightValue>>, TRightValue>";
	var noFilterLsM = $"NoFilter<{nonExecBuilderLsM}>";
	var joinFilterLsM = $"JoinFilter<{nonExecBuilderLsM}>";
	var joinFilterArgLsM = $"JoinFilterWithArg<{nonExecBuilderLsM}, TArg>";
	var resolverNoFilterLsM = $"JoinManyLeftSymResolver<TKey, TValue, TRightCache, TLookupKey, TLookupKey, TRightKey, TRightValue, {noFilterLsM}, IdentitySelector<TLookupKey>>";
	var resolverFilterLsM = $"JoinManyLeftSymResolver<TKey, TValue, TRightCache, TLookupKey, TLookupKey, TRightKey, TRightValue, {joinFilterLsM}, IdentitySelector<TLookupKey>>";
	var resolverFilterArgLsM = $"JoinManyLeftSymResolver<TKey, TValue, TRightCache, TLookupKey, TLookupKey, TRightKey, TRightValue, {joinFilterArgLsM}, IdentitySelector<TLookupKey>>";
	var methodTypeParamsLsM = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TLookupKey, TRightCache, TRightKey, TRightValue>";
	var methodTypeParamsLsMArg = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TLookupKey, TRightCache, TRightKey, TArg, TRightValue>";

	// ── Phase 4b: selector helper fragments ─────────────────────────────────
	// RightListIndex selector (outer only — inner selector deferred per Phase 1).
	// Paired core's TLeft is TKey; selector maps TKey → TIndexKey.
	var keySelectorRListSel = "KeySelector<TKey, TIndexKey>";
	var keySelectorArgRListSel = "KeySelectorWithArg<TKey, TSelectorArg, TIndexKey>";
	var joinFilterArgMF = $"JoinFilterWithArg<{nonExecBuilderM}, TFilterArg>";
	var resolverRListSelS1 = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TIndexKey, TRightValue, {noFilterM}, {keySelectorRListSel}>";
	var resolverRListSelS2 = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TIndexKey, TRightValue, {noFilterM}, {keySelectorArgRListSel}>";
	var resolverRListSelS3 = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TIndexKey, TRightValue, {joinFilterM}, {keySelectorRListSel}>";
	var resolverRListSelS4 = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TIndexKey, TRightValue, {joinFilterM}, {keySelectorArgRListSel}>";
	var resolverRListSelS5 = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TIndexKey, TRightValue, {joinFilterArgMF}, {keySelectorRListSel}>";
	var resolverRListSelS6 = $"JoinManyRightListIndexResolver<TKey, TValue, TRightCache, TRightKey, TIndexKey, TRightValue, {joinFilterArgMF}, {keySelectorArgRListSel}>";
	var methodTypeParamsRListSel = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TIndexKey, TRightCache, TRightKey, TRightValue>";
	var methodTypeParamsRListSelSArg = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TSelectorArg, TIndexKey, TRightCache, TRightKey, TRightValue>";
	var methodTypeParamsRListSelFArg = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TIndexKey, TRightCache, TRightKey, TFilterArg, TRightValue>";
	var methodTypeParamsRListSelSFArg = $"<TDiscriminator, TExecutor, TResolverChain, TKey, TValue{extraTs}, TSelectorArg, TIndexKey, TRightCache, TRightKey, TFilterArg, TRightValue>";

