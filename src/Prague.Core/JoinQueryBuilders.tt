			index.Reverse, index.Forward, (TRightCache)rightCache, default);
		return Unsafe.AsRef(in builder).AddResolver<Resolvers<TResolverChain, <#= resolverCollFwdNoFilter #>>, <#= nextResultMany #>>(
			new Resolvers<TResolverChain, <#= resolverCollFwdNoFilter #>>(builder._resolverChain, resolver), true);
	}

