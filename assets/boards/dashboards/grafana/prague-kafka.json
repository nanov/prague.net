{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the Prague.Kafka meter",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "OpenTelemetry metrics emitted by Prague.Kafka.AddPragueKafkaInstrumentation(). Health, throughput, sizes per consumer and cache.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Healthy consumers",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(prague_kafka_consumer_health{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\"})",
          "legendFormat": "healthy",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Healthy caches",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(prague_kafka_cache_health{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\", cache=~\"$cache\"})",
          "legendFormat": "healthy",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total cache rows",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(prague_kafka_cache_size{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\", cache=~\"$cache\"})",
          "legendFormat": "rows",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Messages received / sec",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "cps",
          "decimals": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(prague_kafka_cache_messages_received_total{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\", cache=~\"$cache\"}[1m]))",
          "legendFormat": "msg/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Consumer health (1 = healthy, 0 = unhealthy)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10, "showPoints": "auto" },
          "min": 0,
          "max": 1,
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "prague_kafka_consumer_health{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\"}",
          "legendFormat": "{{consumer}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cache health (1 = healthy, 0 = unhealthy)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10, "showPoints": "auto" },
          "min": 0,
          "max": 1,
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "prague_kafka_cache_health{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\", cache=~\"$cache\"}",
          "legendFormat": "{{consumer}} / {{cache}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Messages received — rate / sec, by cache",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 },
          "unit": "cps",
          "decimals": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (consumer, cache) (rate(prague_kafka_cache_messages_received_total{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\", cache=~\"$cache\"}[1m]))",
          "legendFormat": "{{consumer}} / {{cache}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Cache size (live rows), by cache",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "prague_kafka_cache_size{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\", cache=~\"$cache\"}",
          "legendFormat": "{{consumer}} / {{cache}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Broker RTT p99 (max across brokers), by consumer",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 5 },
          "unit": "ms",
          "decimals": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "prague_kafka_consumer_broker_rtt_p99{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\"}",
          "legendFormat": "{{consumer}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Partitions assigned, by consumer",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10 },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "prague_kafka_consumer_partitions_assigned{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\"}",
          "legendFormat": "{{consumer}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Index size — keys, by (cache, index)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 5 },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "prague_kafka_cache_index_size{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\", cache=~\"$cache\", kind=\"keys\"}",
          "legendFormat": "{{cache}} / {{index}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Index size — values, by (cache, index)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 5 },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "prague_kafka_cache_index_size{k8s_cluster_name=~\"$k8s_cluster_name\", k8s_pod_name=~\"$k8s_pod_name\", consumer=~\"$consumer\", cache=~\"$cache\", kind=\"values\"}",
          "legendFormat": "{{cache}} / {{index}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["prague", "kafka", "opentelemetry"],
  "templating": {
