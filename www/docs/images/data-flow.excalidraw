		{ "type": "text", "id": "sec1_msg_body", "x": 96, "y": 328, "width": 392, "height": 186, "text": "topic:      orders\nkey:        \"ORD-001\"\nvalue:      Order { CustomerId=42,\n                   Total=99.99m,\n                   CreatedAt=174... }\nheaders:    region=EU, priority=1\ntimestamp:  1747567200000", "originalText": "topic:      orders\nkey:        \"ORD-001\"\nvalue:      Order { CustomerId=42,\n                   Total=99.99m,\n                   CreatedAt=174... }\nheaders:    region=EU, priority=1\ntimestamp:  1747567200000", "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#E4E3E0", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 100017, "version": 1, "versionNonce": 100018, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5 },

