		{ "type": "text", "id": "consumer_title", "x": 676, "y": 264, "width": 360, "height": 18, "text": "KafkaCacheConsumer", "originalText": "KafkaCacheConsumer", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#141414", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 200007, "version": 1, "versionNonce": 200008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
		{ "type": "text", "id": "consumer_steps", "x": 676, "y": 290, "width": 510, "height": 70, "text": "1.  Poll librdkafka  →  ConsumeResult\n2.  Deserialize key (TKey) and value (TValue, MessagePack)\n3.  Apply header & key filters  (composes AND)\n4.  cache.AddOrUpdate(value, timestampMs)", "originalText": "1.  Poll librdkafka  →  ConsumeResult\n2.  Deserialize key (TKey) and value (TValue, MessagePack)\n3.  Apply header & key filters  (composes AND)\n4.  cache.AddOrUpdate(value, timestampMs)", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 200009, "version": 1, "versionNonce": 200010, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.55 },

