		{ "type": "text", "id": "cache_eq", "x": 680, "y": 670, "width": 480, "height": 36, "text": "AddOrUpdate compares via ICacheEquatable<TValue>.\nNo-op when equal → UpdateType.Same  (no index churn).", "originalText": "AddOrUpdate compares via ICacheEquatable<TValue>.\nNo-op when equal → UpdateType.Same  (no index churn).", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#6B7280", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 200039, "version": 1, "versionNonce": 200040, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4 },

